// Cloudflare Workers config — deploys the built Vite app as a static-assets
// Worker (no server code; the backend lives in Supabase Edge Functions).
{
  "name": "captionthis",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
